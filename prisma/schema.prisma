generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// Core Authentication Model
model User {
  id                              BigInt                @id
  email                           String                @unique @db.VarChar(255)
  password                        String?               @db.VarChar(500)
  googleId                        String?               @unique @map("google_id") @db.VarChar(255)
  status                          UserStatus            @default(ACTIVE)
  
  // Email verification
  isEmailVerified                 Boolean               @default(false) @map("is_email_verified")
  pendingEmail                    String?               @unique @db.VarChar(255) @map("pending_email")
  emailVerificationToken          String?               @unique @db.VarChar(255) @map("email_verification_token")
  emailVerificationTokenExpiresAt DateTime?             @map("email_verification_token_expires_at")
  emailVerificationSentAt         DateTime?             @map("email_verification_sent_at")
  
  // Two-factor authentication
  twoFactorEnabled                Boolean               @default(false) @map("two_factor_enabled")
  twoFactorSecret                 String?               @db.VarChar(1000) @map("two_factor_secret")
  twoFactorMethod                 TwoFactorMethodType?  @map("two_factor_method")
  twoFactorVerifiedAt             DateTime?             @map("two_factor_verified_at")
  
  // Security
  passwordChangedAt               DateTime?             @map("password_changed_at")
  roleId                          BigInt?               @map("role_id")
  
  // Audit fields
  createdAt                       DateTime              @default(now()) @map("created_at")
  updatedAt                       DateTime              @updatedAt @map("updated_at")
  createdById                     BigInt?               @map("created_by_id")
  updatedById                     BigInt?               @map("updated_by_id")
  deletedById                     BigInt?               @map("deleted_by_id")
  deletedAt                       DateTime?             @map("deleted_at")
  isActive                        Boolean               @default(true) @map("is_active")
  isDeleted                       Boolean               @default(false) @map("is_deleted")
  version                         Int                   @default(1)
  
  // Essential relations only
  role                            Role?                 @relation(fields: [roleId], references: [id])
  userProfile                     UserProfile?
  devices                         Device[]
  auditLogs                       AuditLog[]            @relation("AuditLog")
  recoveryCodes                   RecoveryCode[]        @relation("RecoveryCode")
  
  // Business relations (move to separate junction tables if needed)
  orders                          Order[]
  reviews                         Review[]
  carts                           CartItem[]
  
  // Audit relations (created by, updated by, deleted by)
  createdRoles                    Role[]                @relation("RoleCreatedBy")
  updatedRoles                    Role[]                @relation("RoleUpdatedBy") 
  deletedRoles                    Role[]                @relation("RoleDeletedBy")
  createdPermissions              Permission[]          @relation("PermissionCreatedBy")
  updatedPermissions              Permission[]          @relation("PermissionUpdatedBy")
  deletedPermissions              Permission[]          @relation("PermissionDeletedBy")
  assignedRolePermissions         RolePermission[]      @relation("RolePermissionAssignedBy")
  createdRolePermissions          RolePermission[]      @relation("RolePermissionCreatedBy")
  updatedRolePermissions          RolePermission[]      @relation("RolePermissionUpdatedBy")
  deletedRolePermissions          RolePermission[]      @relation("RolePermissionDeletedBy")
  createdProducts                 Product[]             @relation("ProductCreatedBy")
  updatedProducts                 Product[]             @relation("ProductUpdatedBy")
  deletedProducts                 Product[]             @relation("ProductDeletedBy")
  createdProductCodes             ProductCode[]         @relation("ProductCodeCreatedBy")
  updatedProductCodes             ProductCode[]         @relation("ProductCodeUpdatedBy")
  deletedProductCodes             ProductCode[]         @relation("ProductCodeDeletedBy")
  createdProductTranslations      ProductTranslation[]  @relation("ProductTranslationCreatedBy")
  updatedProductTranslations      ProductTranslation[]  @relation("ProductTranslationUpdatedBy")
  deletedProductTranslations      ProductTranslation[]  @relation("ProductTranslationDeletedBy")
  createdCategories               Category[]            @relation("CategoryCreatedBy")
  updatedCategories               Category[]            @relation("CategoryUpdatedBy")
  deletedCategories               Category[]            @relation("CategoryDeletedBy")
  createdCategoryTranslations     CategoryTranslation[] @relation("CategoryTranslationCreatedBy")
  updatedCategoryTranslations     CategoryTranslation[] @relation("CategoryTranslationUpdatedBy")
  deletedCategoryTranslations     CategoryTranslation[] @relation("CategoryTranslationDeletedBy")
  createdVariants                 Variant[]             @relation("VariantCreatedBy")
  updatedVariants                 Variant[]             @relation("VariantUpdatedBy")
  deletedVariants                 Variant[]             @relation("VariantDeletedBy")
  createdVariantOptions           VariantOption[]       @relation("VariantOptionCreatedBy")
  updatedVariantOptions           VariantOption[]       @relation("VariantOptionUpdatedBy")
  deletedVariantOptions           VariantOption[]       @relation("VariantOptionDeletedBy")
  createdSKUs                     SKU[]                 @relation("SKUCreatedBy")
  updatedSKUs                     SKU[]                 @relation("SKUUpdatedBy")
  deletedSKUs                     SKU[]                 @relation("SKUDeletedBy")
  createdBrands                   Brand[]               @relation("BrandCreatedBy")
  updatedBrands                   Brand[]               @relation("BrandUpdatedBy")
  deletedBrands                   Brand[]               @relation("BrandDeletedBy")
  createdBrandTranslations        BrandTranslation[]    @relation("BrandTranslationCreatedBy")
  updatedBrandTranslations        BrandTranslation[]    @relation("BrandTranslationUpdatedBy")
  deletedBrandTranslations        BrandTranslation[]    @relation("BrandTranslationDeletedBy")
  createdLanguages                Language[]            @relation("LanguageCreatedBy")
  updatedLanguages                Language[]            @relation("LanguageUpdatedBy")
  deletedLanguages                Language[]            @relation("LanguageDeletedBy")
  createdOrders                   Order[]               @relation("OrderCreatedBy")
  updatedOrders                   Order[]               @relation("OrderUpdatedBy")
  deletedOrders                   Order[]               @relation("OrderDeletedBy")
  sentMessages                    Message[]             @relation("FromUser")
  receivedMessages                Message[]             @relation("ToUser")
  createdMessages                 Message[]             @relation("MessageCreatedBy")
  updatedMessages                 Message[]             @relation("MessageUpdatedBy")
  deletedMessages                 Message[]             @relation("MessageDeletedBy")
  userTranslations                UserTranslation[]     @relation("UserTranslation")
  createdUserTranslations         UserTranslation[]     @relation("UserTranslationCreatedBy")
  updatedUserTranslations         UserTranslation[]     @relation("UserTranslationUpdatedBy")
  deletedUserTranslations         UserTranslation[]     @relation("UserTranslationDeletedBy")
  createdUserProfiles             UserProfile[]         @relation("UserProfileCreatedBy")
  updatedUserProfiles             UserProfile[]         @relation("UserProfileUpdatedBy")
  deletedUserProfiles             UserProfile[]         @relation("UserProfileDeletedBy")
  createdDevices                  Device[]              @relation("DeviceCreatedBy")
  updatedDevices                  Device[]              @relation("DeviceUpdatedBy")
  deletedDevices                  Device[]              @relation("DeviceDeletedBy")
  createdCartItems                CartItem[]            @relation("CartItemCreatedBy")
  updatedCartItems                CartItem[]            @relation("CartItemUpdatedBy")
  deletedCartItems                CartItem[]            @relation("CartItemDeletedBy")
  createdProductSKUSnapshots      ProductSKUSnapshot[]  @relation("ProductSKUSnapshotCreatedBy")
  updatedProductSKUSnapshots      ProductSKUSnapshot[]  @relation("ProductSKUSnapshotUpdatedBy")
  deletedProductSKUSnapshots      ProductSKUSnapshot[]  @relation("ProductSKUSnapshotDeletedBy")
  createdReviews                  Review[]              @relation("ReviewCreatedBy")
  updatedReviews                  Review[]              @relation("ReviewUpdatedBy")
  deletedReviews                  Review[]              @relation("ReviewDeletedBy")
  createdPaymentTransactions      PaymentTransaction[]  @relation("PaymentTransactionCreatedBy")
  updatedPaymentTransactions      PaymentTransaction[]  @relation("PaymentTransactionUpdatedBy")
  deletedPaymentTransactions      PaymentTransaction[]  @relation("PaymentTransactionDeletedBy")
  createdRecoveryCodes            RecoveryCode[]        @relation("RecoveryCodeCreatedBy")
  updatedRecoveryCodes            RecoveryCode[]        @relation("RecoveryCodeUpdatedBy")
  deletedRecoveryCodes            RecoveryCode[]        @relation("RecoveryCodeDeletedBy")
  createdAuditLogs                AuditLog[]            @relation("AuditLogCreatedBy")
  updatedAuditLogs                AuditLog[]            @relation("AuditLogUpdatedBy")
  deletedAuditLogs                AuditLog[]            @relation("AuditLogDeletedBy")

  @@map("users")
  @@index([email])
  @@index([status])
  @@index([roleId])
}

// Extended Profile Information
model UserProfile {
  id                    BigInt    @id
  userId                BigInt    @unique @map("user_id")
  
  // Personal information
  firstName             String?   @db.VarChar(100) @map("first_name")
  lastName              String?   @db.VarChar(100) @map("last_name")
  username              String?   @unique @db.VarChar(100)
  displayName           String?   @db.VarChar(200) @map("display_name")
  avatar                String?   @db.VarChar(1000)
  bio                   String?   @db.Text
  dateOfBirth           DateTime? @map("date_of_birth")
  gender                String?   @db.VarChar(20)
  
  // Contact information
  phoneNumber           String?   @unique @db.VarChar(50) @map("phone_number")
  isPhoneNumberVerified Boolean   @default(false) @map("is_phone_number_verified")
  phoneNumberVerifiedAt DateTime? @map("phone_number_verified_at")
  countryCode           String?   @db.VarChar(10) @map("country_code")
  
  // Address information
  defaultShippingAddress String?   @db.Text @map("default_shipping_address")
  defaultBillingAddress  String?   @db.Text @map("default_billing_address")
  
  // Preferences
  language              String?   @db.VarChar(10) @default("en")
  timezone              String?   @db.VarChar(50) @default("UTC")
  currency              String?   @db.VarChar(3) @default("USD")
  
  // Privacy settings
  isProfilePublic       Boolean   @default(false) @map("is_profile_public")
  allowMarketing        Boolean   @default(false) @map("allow_marketing")
  
  // Audit fields
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  createdById           BigInt?   @map("created_by_id")
  updatedById           BigInt?   @map("updated_by_id")
  deletedById           BigInt?   @map("deleted_by_id")
  deletedAt             DateTime? @map("deleted_at")
  isActive              Boolean   @default(true) @map("is_active")
  isDeleted             Boolean   @default(false) @map("is_deleted")
  version               Int       @default(1)
  
  // Relations
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdBy             User?     @relation("UserProfileCreatedBy", fields: [createdById], references: [id])
  updatedBy             User?     @relation("UserProfileUpdatedBy", fields: [updatedById], references: [id])
  deletedBy             User?     @relation("UserProfileDeletedBy", fields: [deletedById], references: [id])

  @@map("user_profiles")
  @@index([userId])
  @@index([username])
  @@index([phoneNumber])
}

// Model Device
model Device {
  id                     BigInt    @id
  userId                 BigInt    @map("user_id")
  name                   String?   @db.VarChar(255)
  fingerprint            String?   @unique @db.VarChar(255)
  userAgent              String    @map("user_agent") @db.VarChar(255)
  ip                     String    @db.VarChar(45)
  lastActive             DateTime  @updatedAt @map("last_active")
  isTrusted              Boolean   @default(false) @map("is_trusted")
  lastKnownIp            String?   @db.VarChar(45) @map("last_known_ip")
  lastKnownCountry       String?   @db.VarChar(100) @map("last_known_country")
  lastKnownCity          String?   @db.VarChar(100) @map("last_known_city")
  lastNotificationSentAt DateTime? @map("last_notification_sent_at")
  trustExpiration        DateTime? @map("trust_expiration")
  browser                String?   @db.VarChar(100)
  browserVersion         String?   @db.VarChar(50) @map("browser_version")
  os                     String?   @db.VarChar(100)
  osVersion              String?   @db.VarChar(50) @map("os_version")
  deviceType             String?   @db.VarChar(50) @map("device_type")
  deviceVendor           String?   @db.VarChar(100) @map("device_vendor")
  deviceModel            String?   @db.VarChar(100) @map("device_model")
  
  // Audit fields
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  createdById            BigInt?   @map("created_by_id")
  updatedById            BigInt?   @map("updated_by_id")  
  deletedById            BigInt?   @map("deleted_by_id")
  deletedAt              DateTime? @map("deleted_at")
  isActive               Boolean   @default(true) @map("is_active")
  isDeleted              Boolean   @default(false) @map("is_deleted")
  version                Int       @default(1)
  
  // Relations
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdBy              User?     @relation("DeviceCreatedBy", fields: [createdById], references: [id])
  updatedBy              User?     @relation("DeviceUpdatedBy", fields: [updatedById], references: [id])
  deletedBy              User?     @relation("DeviceDeletedBy", fields: [deletedById], references: [id])

  @@map("devices")
  @@index([userId, fingerprint])
  @@index([userId, lastActive])
  @@index([userId, browser, os])
  @@index([isDeleted])
  @@index([isTrusted])
}

// Model Role
model Role {
  id           BigInt           @id
  name         String           @unique @db.VarChar(100)
  description  String?          @db.Text
  isSystemRole Boolean          @default(false) @map("is_system_role")
  isSuperAdmin Boolean          @default(false) @map("is_super_admin")
  
  // Audit fields
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  createdById  BigInt?          @map("created_by_id")
  updatedById  BigInt?          @map("updated_by_id")
  deletedById  BigInt?          @map("deleted_by_id")
  deletedAt    DateTime?        @map("deleted_at")
  isActive     Boolean          @default(true) @map("is_active")
  isDeleted    Boolean          @default(false) @map("is_deleted")
  version      Int              @default(1)
  
  // Relations
  createdBy    User?            @relation("RoleCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?            @relation("RoleUpdatedBy", fields: [updatedById], references: [id])
  deletedBy    User?            @relation("RoleDeletedBy", fields: [deletedById], references: [id])
  permissions  RolePermission[]
  users        User[]

  @@map("roles")
  @@index([name])
  @@index([isSystemRole])
  @@index([isSuperAdmin])
  @@index([isDeleted])
  @@index([createdById])
}

// Model Permission
model Permission {
  id                 BigInt           @id @default(autoincrement())
  action             String           @db.VarChar(100)
  subject            String           @db.VarChar(255)
  conditions         Json?            @db.Json
  description        String?          @db.Text
  isSystemPermission Boolean          @default(false) @map("is_system_permission")
  
  // Audit fields
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  createdById        BigInt?          @map("created_by_id")
  updatedById        BigInt?          @map("updated_by_id")
  deletedById        BigInt?          @map("deleted_by_id")
  deletedAt          DateTime?        @map("deleted_at")
  isActive           Boolean          @default(true) @map("is_active")
  isDeleted          Boolean          @default(false) @map("is_deleted")
  version            Int              @default(1)
  
  // Relations
  createdBy          User?            @relation("PermissionCreatedBy", fields: [createdById], references: [id])
  updatedBy          User?            @relation("PermissionUpdatedBy", fields: [updatedById], references: [id])
  deletedBy          User?            @relation("PermissionDeletedBy", fields: [deletedById], references: [id])
  roles              RolePermission[]

  @@map("permissions")
  @@unique([action, subject])
  @@index([subject, action])
  @@index([isSystemPermission])
  @@index([isDeleted])
  @@index([createdById])
}

// Model RolePermission
model RolePermission {
  roleId       BigInt    @map("role_id")
  permissionId BigInt    @map("permission_id")
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  assignedById BigInt?   @map("assigned_by_id")
  
  // Audit fields
  createdAt    DateTime  @default(now()) @map("created_at")  
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdById  BigInt?   @map("created_by_id")
  updatedById  BigInt?   @map("updated_by_id")
  deletedById  BigInt?   @map("deleted_by_id")
  deletedAt    DateTime? @map("deleted_at")
  isActive     Boolean   @default(true) @map("is_active")
  isDeleted    Boolean   @default(false) @map("is_deleted")
  version      Int       @default(1)
  
  // Relations
  assignedBy   User?     @relation("RolePermissionAssignedBy", fields: [assignedById], references: [id])
  createdBy    User?     @relation("RolePermissionCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?     @relation("RolePermissionUpdatedBy", fields: [updatedById], references: [id])
  deletedBy    User?     @relation("RolePermissionDeletedBy", fields: [deletedById], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@map("role_permissions")
  @@id([roleId, permissionId])
  @@index([assignedById])
  @@index([assignedAt])
  @@index([isDeleted])
}

// Model Product
model Product {
  id              BigInt               @id
  basePrice       Float                @map("base_price")
  virtualPrice    Float                @map("virtual_price")
  brandId         BigInt               @map("brand_id")
  images          String[]             @db.Text
  productCodeId   BigInt?              @unique @map("product_code_id")
  
  // Audit fields
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  createdById     BigInt?              @map("created_by_id")
  updatedById     BigInt?              @map("updated_by_id")
  deletedById     BigInt?              @map("deleted_by_id")
  deletedAt       DateTime?            @map("deleted_at")
  isActive        Boolean              @default(true) @map("is_active")
  isDeleted       Boolean              @default(false) @map("is_deleted")
  version         Int                  @default(1)
  
  // Relations
  brand               Brand                @relation(fields: [brandId], references: [id])
  productCode         ProductCode?         @relation(fields: [productCodeId], references: [id])
  createdBy           User?                @relation("ProductCreatedBy", fields: [createdById], references: [id])
  updatedBy           User?                @relation("ProductUpdatedBy", fields: [updatedById], references: [id])
  deletedBy           User?                @relation("ProductDeletedBy", fields: [deletedById], references: [id])
  productTranslations ProductTranslation[]
  reviews             Review[]
  skus                SKU[]
  variants            Variant[]
  categories          Category[]           @relation("CategoryToProduct")

  @@map("products")
  @@index([brandId])
  @@index([productCodeId])
  @@index([basePrice])
  @@index([isDeleted])
  @@index([createdById])
  @@index([createdAt])
}

// Model ProductCode
model ProductCode {
  id        BigInt @id
  code      String @unique @db.VarChar(50)
  
  // Audit fields
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById BigInt?  @map("created_by_id")
  updatedById BigInt?  @map("updated_by_id")
  deletedById BigInt?  @map("deleted_by_id")
  deletedAt   DateTime? @map("deleted_at")
  isActive    Boolean  @default(true) @map("is_active")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  version     Int      @default(1)
  
  // Relations
  product   Product? @relation
  createdBy User?    @relation("ProductCodeCreatedBy", fields: [createdById], references: [id])
  updatedBy User?    @relation("ProductCodeUpdatedBy", fields: [updatedById], references: [id])
  deletedBy User?    @relation("ProductCodeDeletedBy", fields: [deletedById], references: [id])

  @@map("product_codes")
  @@index([code])
  @@index([isDeleted])
}

// Model ProductTranslation
model ProductTranslation {
  id          BigInt    @id
  productId   BigInt    @map("product_id")
  languageId  BigInt    @map("language_id")
  name        String    @db.VarChar(500)
  description String    @db.Text
  
  // Audit fields
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdById BigInt?   @map("created_by_id")
  updatedById BigInt?   @map("updated_by_id")
  deletedById BigInt?   @map("deleted_by_id")
  deletedAt   DateTime? @map("deleted_at")
  isActive    Boolean   @default(true) @map("is_active")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  version     Int       @default(1)
  
  // Relations
  createdBy   User?     @relation("ProductTranslationCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?     @relation("ProductTranslationUpdatedBy", fields: [updatedById], references: [id])
  deletedBy   User?     @relation("ProductTranslationDeletedBy", fields: [deletedById], references: [id])
  language    Language  @relation(fields: [languageId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_translations")
  @@unique([productId, languageId])
  @@index([productId])
  @@index([languageId])
  @@index([name])
  @@index([isDeleted])
}

// Model Category
model Category {
  id                   BigInt                @id
  name                 String                @unique @db.VarChar(255)
  description          String?               @db.Text
  parentId             BigInt?               @map("parent_id")
  
  // Audit fields
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  createdById          BigInt?               @map("created_by_id")
  updatedById          BigInt?               @map("updated_by_id")
  deletedById          BigInt?               @map("deleted_by_id")
  deletedAt            DateTime?             @map("deleted_at")
  isActive             Boolean               @default(true) @map("is_active")
  isDeleted            Boolean               @default(false) @map("is_deleted")
  version              Int                   @default(1)
  
  // Relations
  createdBy            User?                 @relation("CategoryCreatedBy", fields: [createdById], references: [id])
  updatedBy            User?                 @relation("CategoryUpdatedBy", fields: [updatedById], references: [id])
  deletedBy            User?                 @relation("CategoryDeletedBy", fields: [deletedById], references: [id])
  parent               Category?             @relation("SubCategories", fields: [parentId], references: [id])
  children             Category[]            @relation("SubCategories")
  categoryTranslations CategoryTranslation[]
  products             Product[]             @relation("CategoryToProduct")

  @@map("categories")
  @@index([name])
  @@index([parentId])
  @@index([isDeleted])
  @@index([createdById])
  @@index([isActive])
}

// Model CategoryTranslation
model CategoryTranslation {
  id          BigInt    @id
  categoryId  BigInt    @map("category_id")
  languageId  BigInt    @map("language_id")
  name        String    @db.VarChar(500)
  description String    @db.Text
  
  // Audit fields
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdById BigInt?   @map("created_by_id")
  updatedById BigInt?   @map("updated_by_id")
  deletedById BigInt?   @map("deleted_by_id")
  deletedAt   DateTime? @map("deleted_at")
  isActive    Boolean   @default(true) @map("is_active")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  version     Int       @default(1)
  
  // Relations
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  language    Language  @relation(fields: [languageId], references: [id], onDelete: Cascade)
  createdBy   User?     @relation("CategoryTranslationCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?     @relation("CategoryTranslationUpdatedBy", fields: [updatedById], references: [id])
  deletedBy   User?     @relation("CategoryTranslationDeletedBy", fields: [deletedById], references: [id])

  @@map("category_translations")
  @@unique([categoryId, languageId])
  @@index([categoryId])
  @@index([languageId])
  @@index([name])
  @@index([isDeleted])
}

// Model Variant
model Variant {
  id             BigInt          @id
  name           String          @db.VarChar(500)
  productId      BigInt          @map("product_id")
  
  // Audit fields
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  createdById    BigInt?         @map("created_by_id")
  updatedById    BigInt?         @map("updated_by_id")
  deletedById    BigInt?         @map("deleted_by_id")
  deletedAt      DateTime?       @map("deleted_at")
  isActive       Boolean         @default(true) @map("is_active")
  isDeleted      Boolean         @default(false) @map("is_deleted")
  version        Int             @default(1)
  
  // Relations
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy      User?           @relation("VariantCreatedBy", fields: [createdById], references: [id])
  updatedBy      User?           @relation("VariantUpdatedBy", fields: [updatedById], references: [id])
  deletedBy      User?           @relation("VariantDeletedBy", fields: [deletedById], references: [id])
  variantOptions VariantOption[]

  @@map("variants")
  @@index([productId])
  @@index([name])
  @@index([isDeleted])
  @@index([createdById])
}

// Model VariantOption
model VariantOption {
  id          BigInt    @id
  value       String    @db.VarChar(500)
  variantId   BigInt    @map("variant_id")
  
  // Audit fields
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdById BigInt?   @map("created_by_id")
  updatedById BigInt?   @map("updated_by_id")
  deletedById BigInt?   @map("deleted_by_id")
  deletedAt   DateTime? @map("deleted_at")
